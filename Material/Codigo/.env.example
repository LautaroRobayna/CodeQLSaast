# Plantilla de Variables de Entorno
# Copiar este archivo a .env y cambiar los valores según necesidades
# IMPORTANTE: NO commitear archivo .env en control de versiones

## ============================================
## Database Configuration
## ============================================
DB_HOST=pharmago-db
DB_PORT=1433
DB_NAME=PharmaGoDb
DB_USER=sa
DB_PASSWORD=Str0ngP@ssword!

## ============================================
## Backend Configuration (.NET)
## ============================================
# Ambiente: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=5000
BACKEND_PROTOCOL=http

# Connection String (se construye automáticamente si se usan las variables anteriores)
# Si se quiere usar directamente:
DATABASE_CONNECTION_STRING=Server=pharmago-db;Database=PharmaGoDb;User Id=sa;Password=Str0ngP@ssword!

## ============================================
## Frontend Configuration (Angular)
## ============================================
FRONTEND_PORT=4200
FRONTEND_PROTOCOL=http
# URL del API Backend
API_URL=http://localhost:5000

## ============================================
## CORS Configuration
## ============================================
# Separado por comas si hay múltiples orígenes
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80,http://localhost:3000

## ============================================
## Observability Services
## ============================================
# OpenTelemetry Collector
OTLP_COLLECTOR_HOST=otlp-collector
OTLP_COLLECTOR_PORT=4317
OTLP_COLLECTOR_METRICS_PORT=8889
OTLP_COLLECTOR_ENDPOINT=http://otlp-collector:4317

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_HOST=prometheus

# Grafana
GRAFANA_PORT=3000
GRAFANA_HOST=grafana
GRAFANA_ADMIN_PASSWORD=admin

## ============================================
## Nginx Configuration (Frontend)
## ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_UPSTREAM_API=pharmago-api:80
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

## ============================================
## Logging Configuration
## ============================================
LOG_LEVEL=Debug
LOG_OUTPUT=console

## ============================================
## Feature Flags (Opcionales)
## ============================================
FEATURE_SWAGGER_ENABLED=true
FEATURE_METRICS_ENABLED=true

## ============================================
## Security Configuration
## ============================================
SESSION_TIMEOUT=30
JWT_SECRET=dev_jwt_secret_key
VALIDATE_SSL_CERTIFICATES=false
